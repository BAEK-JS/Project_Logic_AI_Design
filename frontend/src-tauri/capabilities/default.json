{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Logic Mapper 메인 윈도우 권한",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "backend",
          "sidecar": true,
          "args": true
        }
      ]
    },
    "shell:allow-open",
    "shell:allow-kill"
  ]
}
